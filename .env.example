# --- Two-repo / local dev (frontend on 5173, backend on 8080) ---
VITE_API_BASE=http://localhost:8080

# Optional: use relative /api URLs so Vite’s dev proxy (vite.config.js) talks to the backend
# (good when CORS or mixed origins confuse things). Leave VITE_API_BASE unset or comment it out.
# VITE_API_RELATIVE=1

# Deployed backend example:
# VITE_API_BASE=https://your-api.example.com
